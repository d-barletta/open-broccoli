rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isRegisteredUser() {
      return isAuthenticated() &&
        request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isNotBanned() {
      return !get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBanned;
    }

    // ── Users ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Restrict reads to the document owner or an admin to prevent any
      // authenticated user from harvesting other users' email addresses.
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Username registry ─────────────────────────────────────────────────
    match /usernames/{username} {
      allow read: if true;
      allow create: if isRegisteredUser();
      allow delete: if isAdmin();
    }

    // ── Admin settings ────────────────────────────────────────────────────
    // public — available model list; readable by all authenticated users
    // secret — OpenRouter API key; readable ONLY by admins in the browser.
    //          The Cloud Function uses the Admin SDK which bypasses these rules.
    // llmStats — aggregate token-usage counters; written by Admin SDK only.
    match /adminSettings/public {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /adminSettings/secret {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /adminSettings/llmStats {
      allow read: if isAdmin();
      allow write: if false; // Admin SDK only
    }

    // ── Per-model LLM usage stats ─────────────────────────────────────────
    // Written exclusively by server-side functions (Admin SDK).
    match /llmStats/{modelDoc} {
      allow read: if isAdmin();
      allow write: if false; // Admin SDK only
    }

    // ── Matches ───────────────────────────────────────────────────────────
    match /matches/{matchId} {
      allow read: if isAuthenticated();
      allow create: if isRegisteredUser() && isNotBanned();
      allow update: if isAuthenticated() && (
        resource.data.player1Uid == request.auth.uid ||
        resource.data.player2Uid == request.auth.uid ||
        resource.data.player2Uid == null
      );
      allow delete: if isAdmin();
    }

    // ── Private player configs ────────────────────────────────────────────
    // Each player can only read/write their own doc. The server-side AI backend
    // reads these via Admin SDK (bypasses rules) to build the AI prompt.
    match /matchPrivate/{docId} {
      allow read: if isAuthenticated() &&
        resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ── Game state ────────────────────────────────────────────────────────
    // All authenticated users can read (spectators too).
    // Only Player 1 can create the initial doc. All subsequent updates are
    // made by the server-side AI backend using the Firebase Admin SDK
    // (Admin SDK bypasses Firestore security rules):
    //   - Vercel: api/ai-move.js (default)
    //   - Firebase CF: functions/index.js (alternative)
    match /gameState/{matchId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        get(/databases/$(database)/documents/matches/$(matchId)).data.player1Uid == request.auth.uid;
      allow delete: if isAdmin();
    }
  }
}
