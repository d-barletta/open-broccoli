rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isNotBanned() {
      return !get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBanned;
    }

    // ── Users ─────────────────────────────────────────────────────────────
    // Any authenticated user can read other users (for leaderboard / match display)
    // Only the user themselves or an admin can write to their profile
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Username registry (for uniqueness checking) ───────────────────────
    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ── Admin settings ────────────────────────────────────────────────────
    // All authenticated users can read settings (needed to fetch the API key
    // and available models). Only admins can write.
    match /adminSettings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Matches ───────────────────────────────────────────────────────────
    match /matches/{matchId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isNotBanned();
      allow update: if isAuthenticated() && (
        resource.data.player1Uid == request.auth.uid ||
        resource.data.player2Uid == request.auth.uid ||
        resource.data.player2Uid == null
      );
      allow delete: if isAdmin();
    }

    // ── Private player configs ────────────────────────────────────────────
    // Each player can only read/write their own private config doc.
    // Doc ID format: {matchId}_p1 or {matchId}_p2
    match /matchPrivate/{docId} {
      // Only the owner of the document can read it
      allow read: if isAuthenticated() &&
        resource.data.uid == request.auth.uid;
      // Allow create for the player who owns it
      allow create: if isAuthenticated() &&
        request.resource.data.uid == request.auth.uid;
      // Allow update only by the doc owner
      allow update: if isAuthenticated() &&
        resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ── Game state ────────────────────────────────────────────────────────
    // Both players (and spectators) can read game state.
    // Only the current player's turn can write (player 1 or player 2 of that match).
    match /gameState/{matchId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        get(/databases/$(database)/documents/matches/$(matchId)).data.player1Uid == request.auth.uid;
      allow update: if isAuthenticated() && (
        get(/databases/$(database)/documents/matches/$(matchId)).data.player1Uid == request.auth.uid ||
        get(/databases/$(database)/documents/matches/$(matchId)).data.player2Uid == request.auth.uid
      );
      allow delete: if isAdmin();
    }
  }
}
